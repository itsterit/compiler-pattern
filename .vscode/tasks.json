{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Echo Workspace Path",
            "type": "shell",
            "command": "echo",
            "args": [
                "Workspace Path:",
                "${workspaceFolder}",
                "-----------------------------------------------------------------------------------------------------------"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "type": "cppbuild",
            "label": "g++.exe build active file",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                /*----------------------------------------------------------------------------------------------------------*/
                /*----------------------------------------------------------------------------------------------------------*/
                "-std=c++17",
                "-fdiagnostics-color=always",
                "-I", "${workspaceFolder}\\main\\src",
                /*----------------------------------------------------------------------------------------------------------*/
                /*----------------------------------------------------------------------------------------------------------*/
                "-g",
                "${workspaceFolder}\\main\\main.cpp",
                /*----------------------------------------------------------------------------------------------------------*/
                /*----------------------------------------------------------------------------------------------------------*/
                "-o",
                "${workspaceFolder}\\release\\compiler_x86.exe",
                /*----------------------------------------------------------------------------------------------------------*/
                /*----------------------------------------------------------------------------------------------------------*/
            ],
            "options": {
                "cwd": "C:\\msys64\\ucrt64\\bin"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "compiler: C:\\msys64\\ucrt64\\bin\\g++.exe",
            "dependsOn": "Echo Workspace Path"
        }
    ]
}