_ERASEPAGE:
    BTSC            NVMCON,         #15
    BRA             _ERASEPAGE
    PUSH            TBLPAG
    MOV             W1,             TBLPAG
    TBLWTL          W0,             [W0]
    MOV             #0X4042,        W0
    MOV             W0,             NVMCON
    DISI            #6
    MOV             #0X55,          W0
    MOV             W0,             NVMKEY
    MOV             #0XAA,          W0
    MOV             W0,             NVMKEY
    BSET            NVMCON,         #15
    NOP
    NOP
ERASING_WAIT_LB:
    BTSC            NVMCON,         #15
    BRA             ERASING_WAIT_LB
    MOV             #1,             W0
    BTSC            NVMCON,         #13
    MOV             #0,             W0
    POP             TBLPAG
    RETURN